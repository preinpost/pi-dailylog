{
  "name": "pi-dailylog",
  "version": "0.1.0",
  "description": "Obsidian 일일 업무일지를 만들고 기록하는 pi 확장 패키지 (순수 로컬, 외부 API 없음).",
  "keywords": [
    "pi-package",
    "obsidian",
    "dailylog",
    "journal"
  ],
  "type": "module",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types test/run.ts"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
